{
  "productName": "Token Monitor",
  "version": "0.1.0",
  "identifier": "com.example.tokenbar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Token Monitor",
        "width": 420,
        "height": 320,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ]
  },
  "plugins": {}
}
