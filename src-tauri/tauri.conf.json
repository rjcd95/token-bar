{
  "productName": "Claude Monitor",
  "version": "0.1.0",
  "identifier": "com.example.claudemonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Monitor",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ],
    "icon": []
  },
  "plugins": {}
}
