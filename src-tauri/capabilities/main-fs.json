{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-fs",
  "description": "File system access for app configuration",
  "windows": ["main"],
  "permissions": [
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPCONFIG" },
        { "path": "$APPCONFIG/*" },
        { "path": "$APPCONFIG/**/*" }
      ]
    }
  ]
}

